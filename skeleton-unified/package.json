    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "happy-dom": "^20.10.6",
    "jsdom": "^25.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
